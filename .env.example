# Copy this file to .env and replace all values before running.

# Database — must match docker-compose.prod.yml
POSTGRES_DB=industry-maintenance-platform
POSTGRES_USER=industry-maintenance-platform_user
POSTGRES_PASSWORD=replace-with-a-strong-password
DATABASE_URL=postgresql://industry-maintenance-platform_user:replace-with-a-strong-password@db:5432/industry-maintenance-platform

# Security — required; app refuses to start if DATABASE_URL is missing
SECRET_KEY=replace-with-a-long-random-string-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=https://localhost,https://127.0.0.1,https://imp.local

# API
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
ENVIRONMENT=production

# Frontend (Vite prefix required)
VITE_API_URL=https://localhost/api
